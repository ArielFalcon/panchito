# ─────────────────────────────────────────────────────────────────────────
# ai-pipeline — variables de entorno (TEMPLATE)
#
# Copia a `.env` y rellena con valores reales. El `.env` está gitignored:
# ninguna URL ni credencial real se commitea en este repositorio.
# ─────────────────────────────────────────────────────────────────────────

# --- Modelo primario: OpenCode Go (hosteado en US, formato OpenAI-compatible) ---
OPENCODE_BASE_URL=
OPENCODE_API_KEY=
OPENCODE_MODEL=

# --- Modelo revisor: Gemini 2.5 Flash (plan pago, sin entrenamiento) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- GitHub (abrir Issues al fallar) ---
GITHUB_TOKEN=

# --- Credenciales de la cuenta de test en DEV (las referencia config/apps/<app>.yaml) ---
DEV_TEST_USER=
DEV_TEST_PASS=

# --- Rutas locales (opcionales) ---
# QA_STORE_DIR=.qa-store
# AI_PIPELINE_ROOT=.
