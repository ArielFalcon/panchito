#!/usr/bin/env bash
# panchito — the Ink terminal UI for the ai-pipeline control API.
# Talks HTTP to a RUNNING orchestrator (docker compose up). Host-only (Node + tsx).
# Env: QA_HOST (default localhost:8080) · QA_API_TOKEN (if the service requires auth).
set -euo pipefail
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
exec node --import tsx "$DIR/src/tui/index.tsx" "$@"
