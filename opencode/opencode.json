{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["./AGENTS.md"],
  "provider": {
    "opencode-go": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenCode Go",
      "options": {
        "baseURL": "{env:OPENCODE_BASE_URL}",
        "apiKey": "{env:OPENCODE_API_KEY}"
      },
      "models": {
        "deepseek-v4-pro": { "name": "DeepSeek V4 Pro" },
        "qwen-3.7-max": { "name": "Qwen 3.7 Max" }
      }
    }
  },
  "agent": {
    "qa-generator": {
      "description": "Genera tests E2E Playwright para el blast radius de un commit y los escribe a disco.",
      "mode": "primary",
      "model": "opencode-go/deepseek-v4-pro",
      "prompt": "{file:./agent/qa-generator.md}",
      "tools": { "write": true, "edit": true, "read": true, "bash": true }
    },
    "qa-reviewer": {
      "description": "Juez independiente de calidad de los E2E. No escribe: emite veredicto JSON.",
      "mode": "subagent",
      "model": "opencode-go/qwen-3.7-max",
      "prompt": "{file:./agent/qa-reviewer.md}",
      "tools": { "write": false, "edit": false, "bash": false, "read": true }
    }
  },
  "mcp": {
    "codegraph": {
      "type": "local",
      "command": ["codegraph-mcp", "--repos", "{env:MIRROR_DIR}"],
      "enabled": true
    },
    "engram": {
      "type": "local",
      "command": ["engram-mcp", "--db", "{env:ENGRAM_DB}"],
      "enabled": true
    }
  }
}
