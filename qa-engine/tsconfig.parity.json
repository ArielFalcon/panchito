{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@kernel/*": ["src/shared-kernel/*"],
      "@contexts/*": ["src/contexts/*"],
      "@interface/*": ["src/interface/*"]
    }
  },
  "include": [
    "test/contexts/generation/infrastructure/dom-snapshot-parity.test.ts",
    "test/contexts/generation/infrastructure/sanitize-text-parity.test.ts",
    "src/shared-kernel/contract/index.ts",
    "test/shared-kernel/run-outcome.test.ts",
    "test/contexts/generation/infrastructure/context-assembler.adapter-parity.test.ts",
    "test/contexts/generation/infrastructure/exploration-brief.adapter-parity.test.ts",
    "test/contexts/generation/infrastructure/verdict-parser.adapter-parity.test.ts",
    "test/contexts/qa-run-orchestration/domain/helpers/error-class-parity.test.ts",
    "test/contexts/cross-run-learning/domain/rule-fold-parity.test.ts",
    "test/contract/seam-parity.contract.test.ts"
  ]
}
