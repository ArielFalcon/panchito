{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": true,
    "allowImportingTsExtensions": true,
    "emitDeclarationOnly": true,
    "outDir": ".tsbuild",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@kernel/*": ["src/shared-kernel/*"],
      "@contexts/*": ["src/contexts/*"],
      "@interface/*": ["src/interface/*"]
    }
  },
  "include": ["src", "test"],
  "exclude": [
    "src/shared-kernel/contract/index.ts",
    "test/shared-kernel/run-outcome.test.ts",
    "test/contexts/change-analysis/domain/commit-classification-parity.test.ts",
    "test/contexts/test-execution/domain/adjudicate-parity.test.ts",
    "test/contexts/generation/application/ports/generation-ports-parity.test.ts",
    "test/contexts/generation/infrastructure/context-assembler.adapter-parity.test.ts",
    "test/contexts/generation/infrastructure/exploration-brief.adapter-parity.test.ts",
    "test/contexts/generation/infrastructure/verdict-parser.adapter-parity.test.ts",
    "test/contexts/generation/infrastructure/plan-parser.adapter-parity.test.ts",
    "test/contexts/test-execution/infrastructure/static-gate-validate-parity.test.ts",
    "test/contexts/generation/application/generate-tests.characterization.test.ts",
    "test/contexts/qa-run-orchestration/domain/helpers/error-class-parity.test.ts",
    "test/contexts/generation/infrastructure/dom-snapshot-parity.test.ts",
    "test/contexts/generation/infrastructure/sanitize-text-parity.test.ts",
    "test/contexts/cross-run-learning/domain/rule-fold-parity.test.ts",
    "test/contract/seam-parity.contract.test.ts"
  ]
}
