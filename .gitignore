node_modules/
dist/
.env
.env.local
config/.api_token
*.log

# Volumen local de artefactos E2E y memoria (se persiste fuera del repo)
.qa-store/
data/
*.db
*.sqlite

# Espejos locales de los repos vigilados
.mirrors/
# Datos de runtime de continuación de runs (regenerable)
.omo/
/.idea/
/.claude/
/.sisyphus/
/.atl/

# TypeScript project-references build artifacts (qa-engine)
qa-engine/.tsbuild/
*.tsbuildinfo
# tsc --build emits .d.ts declarations next to source files when noEmit is ignored in build mode
src/**/*.d.ts

# Test fixtures deliberately named node_modules (walk() skip-set poison fixtures) must be tracked —
# without this exception a plain `git add` silently drops them and the JD-FIX4 tests break on fresh clones.
!qa-engine/test/**/fixtures/**/node_modules/
!qa-engine/test/**/fixtures/**/node_modules/**
