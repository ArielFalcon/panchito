{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": true,
    "allowImportingTsExtensions": true,
    "emitDeclarationOnly": true,
    "outDir": ".tsbuild",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@kernel/*": ["src/shared-kernel/*"],
      "@contexts/*": ["src/contexts/*"],
      "@interface/*": ["src/interface/*"]
    }
  },
  "include": ["src", "test"],
  "exclude": [
    "test/characterization/scenarios.ts",
    "test/characterization/capture-goldens.ts",
    "test/characterization/capture-goldens-b2.ts",
    "src/shared-kernel/contract/index.ts",
    "test/shared-kernel/run-outcome.test.ts",
    "test/shared-kernel/diff-parser/diff-parser-parity.test.ts",
    "test/contexts/change-analysis/domain/commit-classification-parity.test.ts",
    "src/contexts/change-analysis/infrastructure/extractors/default-extractors.ts",
    "test/contexts/test-execution/domain/adjudicate-parity.test.ts",
    "test/contexts/test-execution/domain/selector-check-parity.test.ts",
    "test/contexts/test-execution/domain/progress-gate-parity.test.ts",
    "test/contexts/test-execution/domain/nav-gate-parity.test.ts",
    "test/contexts/objective-signal/domain/decide-coverage-parity.test.ts",
    "test/contexts/objective-signal/infrastructure/fault-injection-oracle-parity.test.ts",
    "test/contexts/objective-signal/infrastructure/lcov-coverage-parity.test.ts",
    "test/contexts/objective-signal/infrastructure/c8-coverage-parity.test.ts",
    "test/contexts/objective-signal/infrastructure/jacoco-coverage-parity.test.ts",
    "test/contexts/objective-signal/infrastructure/v8-browser-coverage-parity.test.ts",
    "test/contexts/workspace-and-publication/domain/write-confinement-parity.test.ts",
    "test/contexts/agent-runtime/infrastructure/codex-error-to-infra-parity.test.ts",
    "test/contexts/agent-runtime/infrastructure/config.adapter-parity.test.ts",
    "test/contexts/generation/application/ports/generation-ports-parity.test.ts",
    "test/contexts/generation/infrastructure/context-assembler.adapter-parity.test.ts",
    "test/contexts/generation/infrastructure/exploration-brief.adapter-parity.test.ts",
    "test/contexts/generation/infrastructure/verdict-parser.adapter-parity.test.ts",
    "test/contexts/generation/infrastructure/plan-parser.adapter-parity.test.ts",
    "test/contexts/test-execution/infrastructure/static-gate-validate-parity.test.ts",
    "test/contexts/generation/application/generate-tests.characterization.test.ts",
    "test/contexts/qa-run-orchestration/infrastructure/legacy-pipeline.adapter.test.ts",
    "test/characterization/golden-parity.test.ts",
    "test/characterization/side-effects.ts",
    "test/characterization/golden-outcome.test.ts",
    "test/contexts/qa-run-orchestration/domain/helpers/derive-cycle-backstop-parity.test.ts",
    "test/contexts/qa-run-orchestration/domain/helpers/should-distill-learning-parity.test.ts",
    "test/contexts/qa-run-orchestration/domain/run-decision-g4-parity.test.ts",
    "test/contexts/qa-run-orchestration/domain/adjudicate-parity.test.ts",
    "test/contexts/qa-run-orchestration/domain/helpers/progress-gate-parity.test.ts",
