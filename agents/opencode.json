  "mcp": {
    "serena": {
      "type": "local",
      "command": [
        "serena",
        "start-mcp-server",
        "--transport",
        "stdio",
        "--context",
        "ide-assistant"
      ],
      "enabled": true
    },
    "engram": {
      "type": "local",
      "command": ["engram", "mcp", "--tools=agent"],
      "environment": { "ENGRAM_DATA_DIR": "{env:ENGRAM_DATA_DIR}" },
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx", "@playwright/mcp",
        "--browser", "chromium",
        "--headless",
        "--timeout-action", "30000",
        "--timeout-navigation", "30000"
      ],
      "enabled": true
    }
  }
