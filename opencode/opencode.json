{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["./AGENTS.md"],
  "server": {
    "port": 4096,
    "hostname": "0.0.0.0"
  },
  "compaction": {
    "auto": true,
    "tail_turns": 2,
    "preserve_recent_tokens": 16000
  },
  "tool_output": {
    "max_lines": 4000,
    "max_bytes": 102400
  },
  "agent": {
    "qa-generator": {
      "description": "Generates Playwright E2E tests for a commit's blast radius and writes them in e2e/.",
      "mode": "primary",
      "model": "opencode-go/deepseek-v4-pro",
      "prompt": "{file:./agent/qa-generator.md}",
      "tools": { "write": true, "edit": true, "read": true, "bash": true, "webfetch": false },
      "mcp": ["serena", "engram", "playwright"],
      "steps": 50,
      "temperature": 0.2
    },
    "qa-reviewer": {
      "description": "Independent E2E quality judge. Does not write: emits a JSON verdict.",
      "mode": "subagent",
      "model": "opencode-go/qwen3.7-max",
      "prompt": "{file:./agent/qa-reviewer.md}",
      "tools": { "write": false, "edit": false, "bash": false, "read": true },
      "steps": 10,
      "temperature": 0.1
    },
    "qa-maintainer": {
      "description": "Self-maintenance agent for ai-pipeline itself. Diagnoses and fixes incidents; never touches watched app repos.",
      "mode": "primary",
      "model": "opencode-go/deepseek-v4-pro",
      "prompt": "{file:./agent/qa-maintainer.md}",
      "tools": { "write": true, "edit": true, "read": true, "bash": true },
      "mcp": ["serena", "engram"],
      "steps": 50,
      "temperature": 0.1
    },
    "qa-assistant": {
      "description": "Read-only run Q&A for the interactive layer (TUI chat). Has engram for persistent chat memory so it remembers past questions in the same session.",
      "mode": "primary",
      "model": "opencode-go/deepseek-v4-flash",
      "prompt": "{file:./agent/qa-assistant.md}",
      "tools": { "write": false, "edit": false, "read": false, "bash": false },
      "mcp": ["engram"],
      "steps": 10,
      "temperature": 0.1
    },
    "qa-worker": {
      "description": "Parallel worker for cheap per-flow test generation in complete/exhaustive mode. Writes ONE spec file per session, scoped to a single flow.",
      "mode": "primary",
      "model": "opencode-go/deepseek-v4-flash",
      "prompt": "{file:./agent/qa-worker.md}",
      "tools": { "write": true, "edit": false, "read": true, "bash": false },
      "mcp": ["serena", "playwright"],
      "steps": 25,
      "temperature": 0.3
    },
    "qa-worker-code": {
      "description": "Parallel worker for code-only objectives (no UI navigation). Same as qa-worker but without the Playwright MCP — no DEV pressure, no browser overhead.",
      "mode": "primary",
      "model": "opencode-go/deepseek-v4-flash",
      "prompt": "{file:./agent/qa-worker.md}",
      "tools": { "write": true, "edit": false, "read": true, "bash": false },
      "mcp": ["serena"],
      "steps": 25,
      "temperature": 0.3
    }
  },
  "mcp": {
    "serena": {
      "type": "local",
      "command": [
        "serena",
        "start-mcp-server",
        "--transport",
        "stdio",
        "--context",
        "ide-assistant"
      ],
      "enabled": true
    },
    "engram": {
      "type": "local",
      "command": ["engram", "mcp", "--tools=agent"],
      "environment": { "ENGRAM_DATA_DIR": "{env:ENGRAM_DATA_DIR}" },
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp", "--browser", "chromium", "--headless"],
      "enabled": true
    }
  }
}
