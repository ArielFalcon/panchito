# ─────────────────────────────────────────────────────────────────────────
# ai-pipeline — environment variables (TEMPLATE)
#
# In production these are injected at runtime by Doppler; no secret is committed.
# Copy to `.env` only to run locally without Doppler.
# ─────────────────────────────────────────────────────────────────────────

# === `orchestrator` container (the Node service) ===========================

# Where `opencode serve` listens inside the agentic-engine container (the `agents` service).
OPENCODE_SERVE_URL=http://agents:4096
# Time budget per agent run (ms). Prevents a hung run from blocking the queue.
OPENCODE_TIMEOUT_MS=900000

# GitHub: clone (private) working copies, open Issues on failure, and open/auto-merge
# the E2E suite PRs. The token needs contents + pull_requests permissions. For
# auto-merge to work, the repo must have "Allow auto-merge" enabled (and usually
# branch protection with required checks); otherwise the PR is left open for a
# manual merge.
GITHUB_TOKEN=
# Identity for the QA commits (optional).
GIT_AUTHOR_NAME=ai-pipeline-qa
GIT_AUTHOR_EMAIL=ai-pipeline-qa@users.noreply.github.com

# Self-maintenance: when an incident is detected, the maintainer agent opens a fix PR and,
# opens a fix PR. Autonomous deploy is OPT-IN (off by default): only the exact string "true"
# enables it. When enabled it auto-deploys through layered safety gates (justification +
# scope/protected-path guard + size guard + rate/loop guard + self-test gate) using a "canary
# before promote" flow — the fix is hot-swapped and proven healthy BEFORE it is merged to main,
# and the boot-guard rolls back a bad swap. Left "false" here so copying this template stays safe;
# set to "true" only when you have branch protection with a required `ci` check on main.
SELF_MAINTAINER_AUTOMERGE=false

# TWO DEV credential layers (do not confuse them; the specs read them from env):
#  1) HTTP Basic gate that protects the WHOLE DEV environment (the browser's native dialog).
DEV_ENV_USER=
DEV_ENV_PASS=
#  2) The APP login via Keycloak (username/password form).
DEV_TEST_USER=
DEV_TEST_PASS=

# Default geolocation for the tests (the app places the user on a map).
PW_GEO_LAT=40.4168
PW_GEO_LNG=-3.7038

# Service / webhook.
PORT=8080
# Webhook HMAC secret (x-hub-signature-256). Leave EMPTY for no signature check.
# Note: do not put an inline `# comment` after the value — docker compose env_file
# treats everything after `=` as the value (the comment would become the secret).
WEBHOOK_SECRET=

# Control-plane API token (the MACHINE credential): protects the operator console / API — every
# non-public route needs `Authorization: Bearer <token>` (only /api/version, /api/health and
# /api/auth/login are public). Leave EMPTY to auto-generate one into config/.api_token on first
# boot; the panchito console auto-discovers it from this var or that file, so you never paste it
# on the same machine. Set a fixed value to pin a known token across restarts / machines.
QA_API_TOKEN=

# GitHub login (the PEOPLE credential). People sign in to the console with their GitHub account
# via the OAuth device flow instead of sharing the token above; the orchestrator authorizes
# collaborators with push access to a watched repo. Set the OAuth App's client id (public, NOT a
# secret) here ONCE — the server advertises it in the version handshake so any console picks it up
# with nothing baked in. The SERVER holds no GitHub app secret. Leave empty to disable GitHub
# login (console falls back to token entry).
GITHUB_OAUTH_CLIENT_ID=

# Optional session settings:
#   AUTH_SIGNING_KEY         - HMAC secret that signs sessions. Defaults to QA_API_TOKEN. Set a
#                              dedicated value to rotate sessions independently of the machine token.
#   AUTH_SESSION_TTL_SECONDS - session lifetime in seconds. Defaults to 86400 (24h).
# Expose the orchestrator over HTTPS in production: a user's GitHub token transits to it at login
# (used read-only, then discarded — never stored or logged).
AUTH_SIGNING_KEY=
AUTH_SESSION_TTL_SECONDS=

# === `agents` container (dual agent runtime + MCP) =========================

# Runtime selection. Defaults are intentionally single-provider:
# - OPENCODE_API_KEY present → single/opencode
# - else CODEX_API_KEY present → single/codex
# - else single/opencode with needs_config in the dashboard
AGENT_RUNTIME_MODE=single
AGENT_SINGLE_PROVIDER=opencode
# Optional role overrides. In dual mode, set at least two visible roles to different
# providers; otherwise the dashboard asks for confirmation and downgrades to single.
AGENT_PRIMARY_PROVIDER=
AGENT_REVIEWER_PROVIDER=
AGENT_CHAT_PROVIDER=
AGENT_PRIMARY_MODEL=
AGENT_REVIEWER_MODEL=
AGENT_CHAT_MODEL=

# OpenCode Go (or Zen) subscription. Through it OpenCode gives
# access to ALL its models; the ones we use (DeepSeek V4 Pro as executor and
# Qwen3.7 Max as reviewer) are selected by name in opencode.json with the
# `opencode-go/` prefix. Obtain it at opencode.ai/auth.
OPENCODE_API_KEY=

# Codex/OpenAI key for the Codex headless runtime.
CODEX_API_KEY=

# Folder (on the volume) for engram's episodic memory (SQLite, self-contained).
ENGRAM_DATA_DIR=/data

# === Shared paths (both containers mount the working-copies volume) =========
MIRROR_DIR=/app/.mirrors
# AI_PIPELINE_ROOT=.   # root the config/e2e seed is read from
# GIT_REMOTE_BASE=https://github.com
