{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@kernel/*": ["src/shared-kernel/*"],
      "@contexts/*": ["src/contexts/*"],
      "@interface/*": ["src/interface/*"]
    }
  },
  "include": [
    "test/contexts/generation/application/ports/generation-ports-parity.test.ts",
    "test/characterization/shadow-run.operator.ts",
    "test/contexts/change-analysis/infrastructure/extractors/symbols-parity.test.ts",
    "test/contexts/change-analysis/infrastructure/extractors/relations-parity.test.ts",
    "test/contexts/change-analysis/infrastructure/extractors/complexity-parity.test.ts",
    "test/contexts/change-analysis/infrastructure/extractors/semantic-diff-parity.test.ts",
    "test/contexts/change-analysis/infrastructure/extractors/patterns-parity.test.ts",
    "test/contexts/generation/infrastructure/dom-snapshot-parity.test.ts",
    "test/contexts/generation/infrastructure/route-catalog-parity.test.ts",
    "test/contexts/generation/infrastructure/sanitize-text-parity.test.ts",
    "test/contexts/generation/infrastructure/context-pack-parity.test.ts"
  ]
}
