{
  "name": "panchito",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "App-agnostic AI-assisted E2E QA engine. Template: a watched app is onboarded via config/ + .env only.",
  "engines": {
    "node": ">=22.19"
  },
  "workspaces": [
    "packages/*",
    "web"
  ],
  "scripts": {
    "qa": "tsx src/cli.ts",
    "onboard": "tsx scripts/onboard-app.ts",
    "contract:gen": "tsx scripts/gen-openapi.ts",
    "sdk:gen": "openapi-typescript contract/openapi.json -o packages/sdk/src/types.gen.ts",
    "sdk:typecheck": "tsc -p packages/sdk",
    "start": "node boot-guard.mjs && tsx src/index.ts",
    "test": "node --import ./test-setup.mjs --import tsx --test \"src/**/*.test.ts\" \"qa-engine/test/**/*.test.ts\" \"packages/sdk/**/*.test.ts\" \"agents/**/*.test.mjs\" \"scripts/**/*.test.ts\"",
    "typecheck": "tsc -b qa-engine/tsconfig.json && tsc --noEmit -p tsconfig.json && tsc --noEmit -p qa-engine/tsconfig.json && tsc --noEmit -p qa-engine/tsconfig.parity.json && tsc --noEmit -p scripts/tsconfig.json",
    "mutate:keystone": "stryker run qa-engine/stryker.conf.json",
    "arch:check": "depcruise --config qa-engine/.dependency-cruiser.cjs qa-engine/src"
  },
  "dependencies": {
    "@opencode-ai/sdk": "1.17.7",
    "@stryker-mutator/core": "^9.6.1",
    "better-sqlite3": "12.10.1",
    "tree-sitter-wasms": "0.1.13",
    "undici": "^8.4.1",
    "web-tree-sitter": "0.20.8",
    "yaml": "^2.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "c8": "^10.1.3",
    "dependency-cruiser": "^17.4.3",
    "openapi-typescript": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
